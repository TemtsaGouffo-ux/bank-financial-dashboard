{
    "name": "Transatlantic (Red & Blue)",
    "dataColors": [
        "#D32F2F", 
        "#003399", 
        "#FF8A65", 
        "#5C6BC0", 
        "#37474F", 
        "#78909C", 
        "#C62828", 
        "#283593"
    ],
    "background": "#F4F6F5",
    "foreground": "#1E293B",
    "tableAccent": "#003399",
    "visualStyles": {
        "*": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#FFFFFF" } },
                        "transparency": 0
                    }
                ],
                "border": [
                    {
                        "show": false
                    }
                ],
                "visualCorners": [
                    {
                        "radius": 8
                    }
                ],
                "title": [
                    {
                        "show": true,
                        "fontFamily": "Segoe UI Semibold",
                        "fontSize": 13,
                        "color": { "solid": { "color": "#1E293B" } }
                    }
                ]
            }
        },
        "page": {
            "*": {
                "background": [
                    {
                        "color": { "solid": { "color": "#F4F6F5" } },
                        "transparency": 0
                    }
                ]
            }
        },
        "card": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#FFFFFF" } }
                    }
                ],
                "labels": [
                    {
                        "color": { "solid": { "color": "#003399" } },
                        "fontSize": 30,
                        "fontFamily": "Segoe UI Bold"
                    }
                ],
                "categoryLabels": [
                    {
                        "color": { "solid": { "color": "#475569" } },
                        "fontSize": 11
                    }
                ]
            }
        },
        "donutChart": {
            "*": {
                "legend": [
                    {
                        "show": true,
                        "position": "Right"
                    }
                ]
            }
        },
        "areaChart": {
            "*": {
                "plotArea": [
                    {
                        "transparency": 30
                    }
                ]
            }
        }
    }
}
{
    "name": "BriqLab School Academic Theme",
    "dataColors": [
        "#D47E44", 
        "#6D3A44", 
        "#333333", 
        "#B26344", 
        "#8B6D81", 
        "#E5A376", 
        "#503036", 
        "#A3A3A3"
    ],
    "background": "#F5E6D8",
    "foreground": "#333333",
    "tableAccent": "#D47E44",
    "visualStyles": {
        "*": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#EAD7C7" } },
                        "transparency": 0
                    }
                ],
                "border": [
                    {
                        "show": false
                    }
                ],
                "visualCorners": [
                    {
                        "radius": 8
                    }
                ],
                "title": [
                    {
                        "show": true,
                        "fontFamily": "Segoe UI Semibold",
                        "fontSize": 13,
                        "color": { "solid": { "color": "#444444" } }
                    }
                ]
            }
        },
        "page": {
            "*": {
                "background": [
                    {
                        "color": { "solid": { "color": "#F5E6D8" } },
                        "transparency": 0
                    }
                ]
            }
        },
        "card": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#E4D0C1" } }
                    }
                ],
                "labels": [
                    {
                        "color": { "solid": { "color": "#444444" } },
                        "fontSize": 30,
                        "fontFamily": "Segoe UI Bold"
                    }
                ],
                "categoryLabels": [
                    {
                        "color": { "solid": { "color": "#666666" } },
                        "fontSize": 11
                    }
                ]
            }
        },
        "donutChart": {
            "*": {
                "legend": [
                    {
                        "show": true,
                        "position": "Right"
                    }
                ]
            }
        },
        "areaChart": {
            "*": {
                "plotArea": [
                    {
                        "transparency": 30
                    }
                ]
            }
        }
    }
}